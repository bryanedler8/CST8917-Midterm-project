{
  "version": "2.0",
  "extensions": {
    "durableTask": {
      "hubName": "PDFAnalyzerHub",
      "storageProvider": {
        "connectionStringName": "AzureWebJobsStorage",
        "partitionCount": 4
      }
    }
  },
  "logging": {
    "logLevel": {
      "default": "Warning",
      "Host.Triggers.DurableTask": "Warning",
      "Host.Triggers.DurableTask.AzureStorage": "Warning"
    }
  },
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.*, 5.0.0)"
  }
}
